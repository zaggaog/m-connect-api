
{
    "php": "8.2",
    "databases": {
        "mysql": {
            "provider": "mysql"
        }
    },
    "build": {
        "commands": [
            "composer install --no-dev",
            "php artisan optimize",
            "php artisan storage:link"
        ]
    },
    "deploy": {
        "commands": [
            "php artisan migrate --force"
        ]
    }
}